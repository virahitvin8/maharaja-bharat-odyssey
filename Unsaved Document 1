import React, { useRef, useEffect, useState } from 'react';
import { useThree } from '@react-three/fiber';
import { Button } from '@/components/ui/button';
import { Play, Pause, Volume2, VolumeX } from 'lucide-react';
// Placeholder for royalty-free Indian-themed music
const MUSIC_URL = 'https://file-examples-com.s3-us-west-2.amazonaws.com/audio/mp3/sample-1.mp3'; // Replace with actual URL if available
export function AudioPlayer() {
  const audioRef = useRef<HTMLAudioElement | null>(null);
  const [isPlaying, setIsPlaying] = useState(false);
  const [isMuted, setIsMuted] = useState(false);
  const [volume, setVolume] = useState(0.5); // Default volume
  const { size } = useThree();
  // Effect to attempt playing music once the canvas is ready
  useEffect(() => {
    if (audioRef.current && size.width > 0 && size.height > 0) {
      const playMusic = async () => {
        try {
          // Attempt to play music. This might fail if user interaction is required.
          await audioRef.current.play();
          setIsPlaying(true);
        } catch (error) {
          console.warn('Audio playback failed. User interaction might be required.', error);
          // Optionally, show a UI prompt to enable audio
        }
      };
      playMusic();
    }
  }, [size]); // Re-run if canvas size changes
  // Effect to set volume and muted state imperatively on the audio element
  useEffect(() => {
    if (audioRef.current) {
      audioRef.current.volume = volume;
      audioRef.current.muted = isMuted;
    }
  }, [volume, isMuted]); // Re-run if volume or muted state changes
  const togglePlayPause = () => {
    if (audioRef.current) {
      if (isPlaying) {
        audioRef.current.pause();
      } else {
        // Attempt to play, handle potential errors
        audioRef.current.play().catch(error => console.warn('Playback failed:', error));
      }
      setIsPlaying(!isPlaying);
    }
  };
  const toggleMute = () => {
    setIsMuted(!isMuted);
    if (audioRef.current) {
      audioRef.current.muted = !isMuted;
      // If unmuting, ensure volume is set correctly
      if (!isMuted) {
        audioRef.current.volume = volume;
      }
    }
  };
  const handleVolumeChange = (event: React.ChangeEvent<HTMLInputElement>) => {
    const newVolume = parseFloat(event.target.value);
    setVolume(newVolume);
    if (audioRef.current) {
      audioRef.current.volume = newVolume;
      // Update muted state if volume changes to 0 or from 0
      setIsMuted(newVolume === 0);
      if (newVolume > 0) {
        audioRef.current.muted = false; // Ensure it's not muted if volume is > 0
      }
    }
  };
  return (
    <div className="absolute bottom-4 left-4 z-40 flex items-center gap-2 glass-dark p-2 rounded-lg shadow-lg">
      {/* Ensure the volume prop is correctly typed and passed */}
      {/* The 'volume' attribute expects a number between 0 and 1. */}
      <audio ref={audioRef} src={MUSIC_URL} loop muted={isMuted} />
      <Button
        variant="ghost"
        size="icon"
        onClick={togglePlayPause}
        className="text-saffron hover:text-white"
      >
        {isPlaying ? <Pause className="w-5 h-5" /> : <Play className="w-5 h-5" />}
      </Button>
      <div className="flex items-center gap-1">
        <Button variant="ghost" size="icon" onClick={toggleMute} className="text-saffron hover:text-white">
          {isMuted || volume === 0 ? <VolumeX className="w-5 h-5" /> : <Volume2 className="w-5 h-5" />}
        </Button>
        <input
          type="range"
          min="0"
          max="1"
          step="0.01"
          value={isMuted ? 0 : volume} // Display 0 if muted, otherwise current volume
          onChange={handleVolumeChange}
          className="w-24 h-2 bg-royal-blue/50 rounded-lg appearance-none cursor-pointer accent-saffron"
          disabled={isMuted} // Disable slider if muted
        />
      </div>
    </div>
  );
}

